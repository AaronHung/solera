# Runtime
SOLERA_ENVIRONMENT=development
SOLERA_DATABASE_URL=sqlite+aiosqlite:///./solera.db
SOLERA_ALLOWED_DOMAINS=["easypi.iiotfab.com","pivision.iiotfab.com"]
SOLERA_ALLOWED_TAGS=["CDT158","CDT159","SINUSOID"]

# Easy PI (read-only Connector)
SOLERA_EASY_PI_BASE_URL=https://easypi.iiotfab.com
SOLERA_EASY_PI_SETTING_NAME=PI-PRD
SOLERA_EASY_PI_TIMEZONE=Asia/Taipei
SOLERA_EASY_PI_TIMEOUT_MS=10000
SOLERA_MAX_RANGE_SECONDS=604800
SOLERA_MAX_POINTS=5000

# Authentication: development tokens are forbidden when ENVIRONMENT=production
SOLERA_DEV_AUTH_ENABLED=true
SOLERA_OIDC_ISSUER=
SOLERA_OIDC_AUDIENCE=
SOLERA_OIDC_JWKS_URL=

# Frontier model gateway. Leave provider disabled until enterprise policy is set.
SOLERA_MODEL_PROVIDER=disabled
SOLERA_MODEL_ENDPOINT=https://api.openai.com/v1/responses
SOLERA_MODEL_NAME=frontier-model
SOLERA_MODEL_API_KEY=
SOLERA_MODEL_DATA_POLICY=summary-only
SOLERA_MODEL_INPUT_COST_PER_MILLION=0
SOLERA_MODEL_OUTPUT_COST_PER_MILLION=0

# Pilot operations
SOLERA_TENANT_REQUESTS_PER_MINUTE=30
SOLERA_TRACE_RETENTION_DAYS=30
SOLERA_AUDIT_RETENTION_DAYS=365
SOLERA_AGGREGATE_RETENTION_DAYS=90

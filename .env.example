# ============================================================
#  Solera v0.1 – Environment Variables Template
#  Copy this file to .env and fill in the real values.
#  .env is gitignored; .env.example is committed (no secrets).
# ============================================================

# ── Runtime ──────────────────────────────────────────────────
SOLERA_ENVIRONMENT=development
# Use SQLite for local dev; switch to Postgres for pilot/production
SOLERA_DATABASE_URL=sqlite+aiosqlite:///./solera.db
# SOLERA_DATABASE_URL=postgresql+asyncpg://solera:CHANGE_ME@localhost:5432/solera

# List fields MUST use JSON array format – pydantic-settings parses list[str]
# as JSON. Comma-separated strings will cause a JSONDecodeError at startup.
# Comments use # only; semicolons (;) are NOT valid in .env files.
SOLERA_ALLOWED_DOMAINS=["easypi.iiotfab.com","pivision.iiotfab.com"]
SOLERA_ALLOWED_TAGS=["CDT158","CDT159","SINUSOID"]

# ── Easy PI Connector (read-only, no auth required) ───────────
SOLERA_EASY_PI_BASE_URL=https://easypi.iiotfab.com
SOLERA_EASY_PI_SETTING_NAME=PI-PRD
SOLERA_EASY_PI_TIMEZONE=Asia/Taipei
SOLERA_EASY_PI_TIMEOUT_MS=10000
SOLERA_MAX_RANGE_SECONDS=604800
SOLERA_MAX_POINTS=5000

# ── PI Vision (browser-side auth only, no server-side key) ───
# The Sidecar reads PI Vision page context via the browser DOM.
# You log into PI Vision directly in the browser.
# Server does not store PI Vision credentials.
#
# PI Vision URL:  https://pivision.iiotfab.com:8443/PIVision
# Login:          administrator / <password>  (browser-only)

# ── Authentication ───────────────────────────────────────────
SOLERA_DEV_AUTH_ENABLED=true
# OIDC – required when ENVIRONMENT=production
SOLERA_OIDC_ISSUER=
SOLERA_OIDC_AUDIENCE=
SOLERA_OIDC_JWKS_URL=

# ── Frontier Model Gateway ────────────────────────────────────
# Provider options:
#   disabled        – deterministic analytics only (no LLM explanation)
#   openai-chat     – OpenAI-compatible Chat Completions (OpenRouter, DeepSeek, etc.)
#   openai-responses – OpenAI Responses API (native OpenAI only)

SOLERA_MODEL_PROVIDER=openai-chat

# OpenRouter endpoint (supports Anthropic, DeepSeek, OpenAI, etc. via one key)
SOLERA_MODEL_ENDPOINT=https://openrouter.ai/api/v1/chat/completions

# Model slug – choose one:
#   anthropic/claude-sonnet-5      ($3/$15 per M tokens – best for demo)
#   deepseek/deepseek-v4-flash     ($0.14/$0.42 per M – cost-efficient)
#   openai/gpt-4o-mini             ($0.15/$0.60 per M – fast)
SOLERA_MODEL_NAME=anthropic/claude-sonnet-5

# Your OpenRouter API key (https://openrouter.ai/keys)
SOLERA_MODEL_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Data sent to the model: none | summary-only | sampled | raw
# summary-only = only aggregated stats, never raw PI values
SOLERA_MODEL_DATA_POLICY=summary-only

# Cost tracking (USD per million tokens for the chosen model)
SOLERA_MODEL_INPUT_COST_PER_MILLION=3.0
SOLERA_MODEL_OUTPUT_COST_PER_MILLION=15.0

# ── Pilot Operations ─────────────────────────────────────────
SOLERA_TENANT_REQUESTS_PER_MINUTE=30
SOLERA_TRACE_RETENTION_DAYS=30
SOLERA_AUDIT_RETENTION_DAYS=365
SOLERA_AGGREGATE_RETENTION_DAYS=90

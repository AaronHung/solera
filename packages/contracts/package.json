{
  "name": "@solera/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./schema": "./schema/solera.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "generate": "node ../../scripts/generate-contract-validators.mjs",
    "build": "npm run generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  }
}
